DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 数据库连接信息
DB_NAME=blog_db
